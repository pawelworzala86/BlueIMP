{
  "name": "blue-imp",
  "version": "0.0.3",
  "bin": {
    "black-hole": "source/compile.js"
  },
  "type": "commonjs",
  "pkg": {
    "scripts": [
      "source/**/*.js"
    ],
    "assets": [
      "source/**/*.js"
    ],
    "noBytecode": true,
    "targets": [
      "node18-win-x64"
    ]
  },
  "description": "",
  "main": "index.js",
  "directories": {
    "example": "examples"
  },
  "scripts": {
    "build": "pkg . --options experimental-modules --output bin/bimp.exe"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pawelworzala86/BlueIMP.git"
  },
  "keywords": [],
  "author": "Paweł Worzała",
  "bugs": {
    "url": "https://github.com/pawelworzala86/BlueIMP/issues"
  },
  "homepage": "https://github.com/pawelworzala86/BlueIMP#readme"
}
